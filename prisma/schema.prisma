generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  SHARED
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  UNAVAILABLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  BOOKING
  MESSAGE
  ALERT
  SYSTEM
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  phone         String?
  password      String?
  image         String?
  role          UserRole @default(TENANT)
  verified      Boolean  @default(false)
  provider      String?
  providerId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties    Property[]
  reviews       Review[]
  notifications Notification[]
  favorites     Favorite[]
  savedSearches SavedSearch[]
  sentMessages  Message[]     @relation("SenderMessages")
  sentBookings  Booking[]     @relation("TenantBookings")

  @@map("users")
}

model Property {
  id              String         @id @default(cuid())
  title           String
  description     String
  price           Int
  type            PropertyType   @default(APARTMENT)
  status          PropertyStatus @default(AVAILABLE)
  bedrooms        Int
  bathrooms       Int
  area            Int
  furnished       Boolean        @default(false)
  petsAllowed     Boolean        @default(false)
  familyFriendly  Boolean        @default(true)
  studentFriendly Boolean        @default(false)
  district        String
  sector          String
  village         String?
  street          String?
  latitude        Float?
  longitude       Float?
  images          String[]
  video           String?
  virtualTour     String?
  amenities       String[]
  availableFrom   DateTime       @default(now())
  featured        Boolean        @default(false)
  verified        Boolean        @default(false)
  aiScore         Int?
  aiEstimatedPrice Int?
  views           Int            @default(0)
  landlordId      String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  landlord        User           @relation(fields: [landlordId], references: [id])
  reviews         Review[]
  bookings        Booking[]
  favorites       Favorite[]
  conversations   Conversation[]

  @@index([district, sector])
  @@index([status])
  @@index([price])
  @@index([landlordId])
  @@map("properties")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  content    String
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@map("reviews")
}

model Booking {
  id         String         @id @default(cuid())
  propertyId String
  tenantId   String
  date       DateTime
  time       String
  status     BookingStatus  @default(PENDING)
  message    String?
  createdAt  DateTime       @default(now())

  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     User           @relation("TenantBookings", fields: [tenantId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
  @@map("bookings")
}

model Conversation {
  id           String    @id @default(cuid())
  propertyId   String?
  participants String[]
  lastMessage  String?
  lastMessageAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property     Property? @relation(fields: [propertyId], references: [id])
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  notify    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}
